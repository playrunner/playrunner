# ── API Server ─────────────────────────────────────────────────────────────────
# Port the Express API listens on (default: 3001)
PORT=3001

# ── Orchestrator / Runner ────────────────────────────────────────────────────────
# Port the orchestrator container is mapped to on the host (default: 3002)
ORCHESTRATOR_PORT=3002

# Full URL the API uses to reach the orchestrator (default: http://localhost:ORCHESTRATOR_PORT)
ORCHESTRATOR_URL=http://localhost:3002

# ── PostgreSQL / Prisma ─────────────────────────────────────────────────────────
# Prisma datasource used by the API application.
# In the standard local flow, setup writes this based on the repo-root `.env.local`.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/playrunner?schema=public"

# Optional: a direct, non-pooled connection string used for migrations or admin tasks.
# DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/playrunner?schema=public"

# Optional: dedicated shadow database used by `prisma migrate dev`.
# SHADOW_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/playrunner_shadow?schema=public"

# Docker image name for the orchestrator container (default: playrunner-orchestrator)
ORCHESTRATOR_IMAGE=playrunner-orchestrator

# EDITOR_API_URL as seen from INSIDE the orchestrator Docker container
# (default: http://host.docker.internal:PORT — works on Docker Desktop for Mac/Windows)
EDITOR_API_URL_DOCKER=http://host.docker.internal:3001

# Optional public base URL that remote runners can call back into for
# execution events and output uploads. Leave blank for pure local Docker workflows.
# EDITOR_API_PUBLIC_URL=https://your-public-api.example.com
