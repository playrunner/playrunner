# ── API Server ─────────────────────────────────────────────────────────────────
# Standard local-flow port for the Express API.
PORT=3011

# Optional: public HTTPS base URL for Cloud Scheduler callbacks to this API.
# Set this when running the API locally and saving an enabled schedule.
# Cloud Scheduler runs in Google Cloud, so it cannot call 127.0.0.1 on your
# machine. Start a Cloudflare Tunnel to this API port:
# cloudflared tunnel --url http://127.0.0.1:3011
# Copy the printed https://...trycloudflare.com URL here, restart the API, then
# save the workflow with the schedule enabled.
# PLAYRUNNER_PUBLIC_API_URL=https://your-tunnel.trycloudflare.com

# ── Orchestrator / Runner ────────────────────────────────────────────────────────
# Standard local-flow host port mapped to the orchestrator container.
ORCHESTRATOR_PORT=3012

# Full URL the API uses to reach the orchestrator.
ORCHESTRATOR_URL=http://localhost:3012

# ── PostgreSQL / Prisma ─────────────────────────────────────────────────────────
# Prisma datasource used by the API application.
# In the standard local flow, setup writes this based on the repo-root `.env.local`.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/playrunner?schema=public"

# AES-256-GCM keyring used to encrypt integration and cloud connection secrets.
# Setup replaces this example with a newly generated 32-byte base64 key.
PLAYRUNNER_CREDENTIAL_ENCRYPTION_KEYS='{"1":"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="}'
PLAYRUNNER_CREDENTIAL_ENCRYPTION_KEY_VERSION=1

# Docker image name for the local orchestrator container (default: playrunner-orchestrator)
LOCAL_ORCHESTRATOR_IMAGE=playrunner-orchestrator

# EDITOR_API_URL as seen from INSIDE the orchestrator Docker container
# (works on Docker Desktop for Mac/Windows)
EDITOR_API_URL_DOCKER=http://host.docker.internal:3011

# Topic used for GCP runner events. Terraform creates the shared topic; the API
# creates a filtered subscription per workflow execution and persists every
# accepted message to PostgreSQL.
GCP_PUBSUB_WORKFLOW_EVENTS_TOPIC=playrunner-workflow-events
