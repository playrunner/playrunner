# ── API Server ─────────────────────────────────────────────────────────────────
# Port the Express API listens on (default: 3001)
PORT=3001

# ── Pub/Sub ─────────────────────────────────────────────────────────────────────
# Pub/Sub topic and subscription names (default: orchestrator-logs / orchestrator-logs-sub)
PUBSUB_TOPIC=orchestrator-logs
PUBSUB_SUBSCRIPTION=orchestrator-logs-sub

# When using the local Pub/Sub emulator, set this to the emulator host:port
# (default: unset — uses real GCP credentials)
PUBSUB_EMULATOR_HOST=localhost:8085

# GCP project ID used by Pub/Sub
PUBSUB_PROJECT_ID=local-dev
GCP_PROJECT=local-dev

# ── Orchestrator / Runner ────────────────────────────────────────────────────────
# Port the orchestrator container is mapped to on the host (default: 3002)
ORCHESTRATOR_PORT=3002

# Full URL the API uses to reach the orchestrator (default: http://localhost:ORCHESTRATOR_PORT)
ORCHESTRATOR_URL=http://localhost:3002

# ── PostgreSQL / Prisma ─────────────────────────────────────────────────────────
# Prisma datasource used by the API application.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/playrunner?schema=public"

# Optional: a direct, non-pooled connection string used for migrations or admin tasks.
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/playrunner?schema=public"

# Optional: dedicated shadow database used by `prisma migrate dev`.
# SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/playrunner_shadow?schema=public"

# ── Local Auth ──────────────────────────────────────────────────────────────────
# Local username configured by the setup wizard and accepted by the web login form.
LOCAL_AUTH_USERNAME=admin

# Password hash generated by the setup wizard. Leave blank until setup writes it.
LOCAL_AUTH_PASSWORD_HASH=

# JWT signing secret used for local auth bearer tokens. Setup will generate one if missing.
AUTH_JWT_SECRET=

# Docker image name for the orchestrator container (default: playrunner-orchestrator)
ORCHESTRATOR_IMAGE=playrunner-orchestrator

# Pub/Sub emulator host as seen from INSIDE Docker containers
# (default: host.docker.internal:8085 — works on Docker Desktop for Mac/Windows)
PUBSUB_EMULATOR_HOST_DOCKER=host.docker.internal:8085

# EDITOR_API_URL as seen from INSIDE the orchestrator Docker container
# (default: http://host.docker.internal:PORT — works on Docker Desktop for Mac/Windows)
EDITOR_API_URL_DOCKER=http://host.docker.internal:3001

# ── GCP Cloud Runner ────────────────────────────────────────────────────────────
# Required when running workflows on GCP. These do not have code defaults.
GCS_BUCKET_PREFIX=your-playrunner-bucket-prefix
GCS_PROJECT_ID=your-gcp-project-id
GCP_CLOUD_RUN_LOCATION=your-cloud-run-region
GCP_ORCHESTRATOR_SERVICE_NAME=your-orchestrator-service-name
GCP_ORCHESTRATOR_IMAGE_URI_TEMPLATE={projectId}/path/to/orchestrator-image:tag
