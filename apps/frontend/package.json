{
  "name": "playrunner-frontend",
  "private": true,
  "version": "0.0.0",
  "author": "Concept AI PTY LTD",
  "license": "SEE LICENSE IN ../../LICENSE",
  "type": "module",
  "scripts": {
    "generate:integrations": "node ../../infra/scripts/generate-integration-composition.mjs . frontend src/integrations/generated-package-contributions.ts",
    "predev": "npm run generate:integrations",
    "dev": "vite",
    "prestart": "npm run generate:integrations",
    "start": "vite build && vite preview",
    "prebuild": "npm run generate:integrations",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "pretypecheck": "npm run generate:integrations",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@monaco-editor/react": "^4.7.0",
    "@playrunner/environment": "file:../../packages/environment",
    "@playrunner/gcp": "file:../../packages/gcp",
    "@playrunner/github": "file:../../packages/github",
    "@playrunner/integration-sdk": "file:../../packages/integration-sdk",
    "@playrunner/javascript": "file:../../packages/javascript",
    "@playrunner/jira": "file:../../packages/jira",
    "@playrunner/playwright": "file:../../packages/playwright",
    "@playrunner/schedule": "file:../../packages/schedule",
    "@playrunner/slack": "file:../../packages/slack",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "prettier": "3.8.4",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.2.3"
  }
}
