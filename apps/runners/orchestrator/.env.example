# ── Orchestrator Runner ──────────────────────────────────────────────────────────
# Port this Express server listens on (default: 3002)
PORT=3002

# URL of the Editor API used for heartbeat checks (default: http://localhost:3001)
EDITOR_API_URL=http://localhost:3001

# ── Pub/Sub ─────────────────────────────────────────────────────────────────────
# Pub/Sub topic for log broadcasting (default: orchestrator-logs)
PUBSUB_TOPIC=orchestrator-logs

# When using the local Pub/Sub emulator, set this to the emulator host:port
PUBSUB_EMULATOR_HOST=localhost:8085

# GCP project ID used by Pub/Sub
PUBSUB_PROJECT_ID=local-dev
GCP_PROJECT=local-dev

# ── Docker / Playwright ──────────────────────────────────────────────────────────
# Base Docker image name prefix for Playwright runner containers
# Runtime suffixes are appended automatically: -typescript / -python
PLAYWRIGHT_IMAGE_BASE=playrunner-playwright-runner
# Pub/Sub emulator host as seen from INSIDE Docker containers
# (default: host.docker.internal:8085 — works on Docker Desktop for Mac/Windows)
PUBSUB_EMULATOR_HOST_DOCKER=host.docker.internal:8085

# GCP project ID passed into Playwright Docker containers
# (default: matches PUBSUB_PROJECT_ID)

# ── GCP Cloud Runner ────────────────────────────────────────────────────────────
# Required when this orchestrator is running GCP-backed Playwright jobs.
GCP_CLOUD_RUN_API_BASE_URL=https://run.googleapis.com/v2
GCP_CLOUD_RUN_LOCATION=your-cloud-run-region
GCP_PLAYWRIGHT_IMAGE_URI_TEMPLATE={projectId}/path/to/playrunner-playwright-runner-{runtime}:{version}
GCP_PLAYWRIGHT_JOB_NAME_TEMPLATE=playrunner-playwright-{runtime}-{version}-{cpu}c-{memory}g
