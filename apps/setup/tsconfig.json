{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@frontend/*": ["../frontend/src/*"],
      "react": [
        "../frontend/node_modules/@types/react",
        "../frontend/node_modules/react"
      ],
      "react/jsx-runtime": [
        "../frontend/node_modules/@types/react/jsx-runtime",
        "../frontend/node_modules/react/jsx-runtime"
      ],
      "react/jsx-dev-runtime": [
        "../frontend/node_modules/@types/react/jsx-dev-runtime",
        "../frontend/node_modules/react/jsx-dev-runtime"
      ],
      "react-dom": ["../frontend/node_modules/react-dom"],
      "react-dom/client": ["../frontend/node_modules/react-dom/client"],
      "react-router-dom": ["../frontend/node_modules/react-router-dom"],
      "lucide-react": ["../frontend/node_modules/lucide-react"],
      "clsx": ["../frontend/node_modules/clsx"],
      "tailwind-merge": ["../frontend/node_modules/tailwind-merge"]
    },
    "allowImportingTsExtensions": true,
    "typeRoots": ["../frontend/node_modules/@types"],
    "noEmit": true
  },
  "include": ["src"]
}
