# Local-only configuration for ./start-local.sh.
# Copy this file to .env.local, then adjust the ports or local database settings if needed.

# Port used by both the normal web app and the setup app.
WEB_PORT=3100

# Port used by the local Docusaurus docs site started by ./start-local.sh.
DOCS_PORT=3104

# Port used by the local setup installer service behind /setup-api.
SETUP_INSTALLER_PORT=3103

# Docker-backed PostgreSQL connection used by the standard local stack.
POSTGRES_PORT=5431
POSTGRES_HOST=127.0.0.1
POSTGRES_DB=playrunner
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Local Pub/Sub emulator used by local runners for the same event/control path
# as cloud runners.
PUBSUB_EMULATOR_PORT=8085
PUBSUB_EMULATOR_HOST=127.0.0.1:8085
LOCAL_PUBSUB_PROJECT_ID=playrunner-local

# Optional: set this to force the API and setup flow to use a non-default
# database URL. If omitted, setup defaults to the Docker-backed Postgres
# connection built from the POSTGRES_* values above.
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/playrunner?schema=public"

# Optional: override only the database URL shown in the setup form while leaving
# runtime DATABASE_URL unchanged.
# VITE_DEFAULT_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/playrunner?schema=public"

# Optional: override the Docs link shown in the frontend. If omitted during the
# standard local flow, ./start-local.sh derives this from DOCS_PORT.
# VITE_DOCS_URL="https://docs.playrunner.dev"
