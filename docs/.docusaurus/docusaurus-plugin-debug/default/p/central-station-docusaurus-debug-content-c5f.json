station/docs/local-dev/firebase-and-data"}},{"id":"local-dev/workflow-execution","title":"Workflow Execution Flow","description":"Local development only. This describes the full journey of a workflow run from the moment you click \"Run\" in the editor.","source":"@site/docs/local-dev/07-workflow-execution.md","sourceDirName":"local-dev","slug":"/local-dev/workflow-execution","permalink":"/central-station/docs/local-dev/workflow-execution","draft":false,"unlisted":false,"editUrl":"https://github.com/playrunner/central-station/tree/main/docs/docs/local-dev/07-workflow-execution.md","tags":[],"version":"current","sidebarPosition":7,"frontMatter":{"sidebar_position":7,"title":"Workflow Execution Flow"},"sidebar":"tutorialSidebar","previous":{"title":"Docker Images","permalink":"/central-station/docs/local-dev/docker-images"},"next":{"title":"Firebase & Data Storage","permalink":"/central-station/docs/local-dev/firebase-and-data"}},{"id":"overview","title":"Overview","description":"Playrunner is a visual workflow orchestration platform for running automated Playwright test pipelines. Connect triggers, integrations, and test runners by dragging nodes on a canvas — no glue code required.","source":"@site/docs/overview.md","sourceDirName":".","slug":"/overview","permalink":"/central-station/docs/overview","draft":false,"unlisted":false,"editUrl":"https://github.com/playrunner/central-station/tree/main/docs/docs/overview.md","tags":[],"version":"current","sidebarPosition":1,"frontMatter":{"sidebar_position":1,"title":"Overview"},"sidebar":"tutorialSidebar","next":{"title":"GCP Cloud Architecture","permalink":"/central-station/docs/gcp-architecture"}},{"id":"tutorials/connect-github","title":"Connect GitHub","description":"Playrunner uses GitHub OAuth to clone your private test repositories. This tutorial shows you how to authenticate, select a repository, and set a target branch.","source":"@site/docs/tutorials/03-connect-github.md","sourceDirName":"tutorials","slug":"/tutorials/connect-github","permalink":"/central-station/docs/tutorials/connect-github","draft":false,"unlisted":false,"editUrl":"https://github.com/playrunner/central-station/tree/main/docs/docs/tutorials/03-connect-github.md","tags":[],"version":"current","sidebarPosition":3,"frontMatter":{"sidebar_position":3,"title":"Connect GitHub"},"sidebar":"tutorialSidebar","previous":{"title":"Create Your First Workflow","permalink":"/central-station/docs/tutorials/create-your-first-workflow"},"next":{"title":"Run Your First Test","permalink":"/central-station/docs/tutorials/run-your-first-test"}},{"id":"tutorials/create-your-first-workflow","title":"Create Your First Workflow","description":"In this tutorial you'll build a simple two-node workflow in the Playrunner visual editor — a Schedule trigger that fires a Playwright test run.","source":"@site/docs/tutorials/02-create-your-first-workflow.md","sourceDirName":"tutorials","slug":"/tutorials/create-your-first-workflow","permalink":"/central-station/docs/tutorials/create-your-first-workflow","draft":false,"unlisted":false,"editUrl":"https://github.com/playrunner/central-station/tree/main/docs/docs/tutorials/02-create-your-first-workflow.md","tags":[],"version":"current","sidebarPosition":2,"frontMatter":{"sidebar_position":2,"title":"Create Your First Workflow"},"sidebar":"tutorialSidebar","previous":{"title":"Getting Started","permalink":"/central-station/docs/tutorials/getting-started"},"next":{"title":"Connect GitHub","permalink":"/central-station/docs/tutorials/connect-github"}},{"id":"tutorials/getting-started","title":"Getting Started","description":"This tutorial walks you through setting up the complete Playrunner local development environment from scratch. By the end you'll have the local stack running, the workspace configured through the setup UI, and the product app ready for login.","source":"@site/docs/tutorials/01-getting-started.md","sourceDirName":"tutorials","slug":"/tutorials/getting-started","permalink":"/ce