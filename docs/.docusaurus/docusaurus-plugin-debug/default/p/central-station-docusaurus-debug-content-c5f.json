bar","previous":{"title":"Connect GitHub","permalink":"/central-station/docs/tutorials/connect-github"},"next":{"title":"Understanding Test Reports","permalink":"/central-station/docs/tutorials/understanding-reports"}},{"id":"tutorials/understanding-reports","title":"Understanding Test Reports","description":"Every Playrunner test run generates a full Playwright HTML report stored with a unique run ID. This tutorial shows you how to navigate the report, find failing tests, and access screenshots and traces.","source":"@site/docs/tutorials/05-understanding-reports.md","sourceDirName":"tutorials","slug":"/tutorials/understanding-reports","permalink":"/central-station/docs/tutorials/understanding-reports","draft":false,"unlisted":false,"editUrl":"https://github.com/playrunner/central-station/tree/main/docs/docs/tutorials/05-understanding-reports.md","tags":[],"version":"current","sidebarPosition":5,"frontMatter":{"sidebar_position":5,"title":"Understanding Test Reports"},"sidebar":"tutorialSidebar","previous":{"title":"Run Your First Test","permalink":"/central-station/docs/tutorials/run-your-first-test"},"next":{"title":"Overview","permalink":"/central-station/docs/local-dev/"}}],"drafts":[],"sidebars":{"tutorialSidebar":[{"type":"doc","id":"overview"},{"type":"doc","id":"gcp-architecture"},{"type":"category","label":"Tutorials","collapsible":true,"collapsed":true,"items":[{"type":"doc","id":"tutorials/getting-started"},{"type":"doc","id":"tutorials/create-your-first-workflow"},{"type":"doc","id":"tutorials/connect-github"},{"type":"doc","id":"tutorials/run-your-first-test"},{"type":"doc","id":"tutorials/understanding-reports"}],"link":{"type":"doc","id":"tutorials/index"}},{"type":"category","label":"Development","collapsible":true,"collapsed":true,"items":[{"type":"doc","id":"local-dev/connecting-integrations"},{"type":"doc","id":"local-dev/services-and-ports"},{"type":"doc","id":"local-dev/connection-nodes"},{"type":"doc","id":"local-dev/environment-variables"},{"type":"doc","id":"local-dev/docker-images"},{"type":"doc","id":"local-dev/workflow-execution"},{"type":"doc","id":"local-dev/firebase-and-data"},{"type":"doc","id":"local-dev/troubleshooting"}],"link":{"type":"doc","id":"local-dev/index"}}]}}]}},"docusaurus-plugin-content-blog":{"default":{"blogTitle":"Blog","blogDescription":"Blog","blogSidebarTitle":"Recent posts","blogPosts":[{"id":"welcome","metadata":{"permalink":"/central-station/blog/welcome","editUrl":"https://github.com/playrunner/central-station/tree/main/docs/blog/2021-08-26-welcome/index.mdx","source":"@site/blog/2021-08-26-welcome/index.mdx","title":"Welcome","description":"Docusaurus blogging features are powered by the blog plugin.","date":"2021-08-26T00:00:00.000Z","tags":[{"inline":false,"label":"Facebook","permalink":"/central-station/blog/tags/facebook","description":"Facebook tag description"},{"inline":false,"label":"Hello","permalink":"/central-station/blog/tags/hello","description":"Hello tag description"},{"inline":false,"label":"Docusaurus","permalink":"/central-station/blog/tags/docusaurus","description":"Docusaurus tag description"}],"readingTime":0.56,"hasTruncateMarker":true,"authors":[{"name":"Sébastien Lorber","title":"Docusaurus maintainer","url":"https://sebastienlorber.com","page":{"permalink":"/central-station/blog/authors/all-sebastien-lorber-articles"},"socials":{"x":"https://x.com/sebastienlorber","linkedin":"https://www.linkedin.com/in/sebastienlorber/","github":"https://github.com/slorber","newsletter":"https://thisweekinreact.com"},"imageURL":"https://github.com/slorber.png","key":"slorber"},{"name":"Yangshun Tay","title":"Ex-Meta Staff Engineer, Co-founder GreatFrontEnd","url":"https://linkedin.com/in/yangshun","page":{"permalink":"/central-station/blog/authors/yangshun"},"socials":{"x":"https://x.com/yangshunz","linkedin":"https://www.linkedin.com/in/yangshun/","github":"https://github.com/yangshun","newsletter":"https://www.greatfrontend.com"},"imageURL":"https://github.com/yangshun.png","key":"yangshun"}],"frontMatter":{"slug":"welcome","title":"Welcome","authors":["slorber","yangshun"],"tags":["facebook","hello","docusaurus"]},"unlisted":false,"nextItem":{"title":"MDX Blog Post","permalink":"/central-station/blog/mdx-blog-post"}},"content":"[Docusaurus blogging features](https://docusaurus.io/docs/blog) are powered by the [blog plugin](https://docusaurus.io/docs/api/plugins/@docusaurus/plugin-content-blog).\n\nHere are a few tips you might find useful.\n\n{/* truncate */}\n\nSimply add Markdown files (or folders) to the `blog` directory.\n\nRegular blog authors can be added to `authors.yml`.\n\nThe blog post date can be extracted from filenames, such as:\n\n- `2019-05-30-welcome.md`\n- `2019-05-30-welcome/index.md`\n\nA blog post folder can be convenient to co-locate blog post images:\n\n![Docusaurus Plushie](./docusaurus-plushie-banner.jpeg)\n\nThe blog supports tags as well!\n\n**And if you don't want a blog**: just delete this directory, and use `blog: false` in your Docusaurus config."},{"id":"mdx-blog-post","metadata":{"permalink":"/central-station/blog/mdx-blog-post","editUrl":"https://github.com/playrunner/central-station/tree/main/docs/blog/2021-08-01-mdx-blog-post.mdx","source":"@site/blog/2021-08-01-mdx-blog-post.mdx","title":"MDX Blog Post","description":"Blog posts support Docusaurus Markdown features, such as MDX.","date":"2021-08-01T00:00:00.000Z","tags":[{"inline":false,"label":"Docusaurus","permalink":"/central-station/blog/tags/docusaurus","description":"Docusaurus tag description"}],"readingTime":0.27,"hasTruncateMarker":true,"authors":[{"name":"Sébastien Lorber","title":"Docusaurus maintainer","url":"https://sebastienlorber.com","page":{"permalink":"/central-station/blog/authors/all-sebastien-lorber-articles"},"socials":{"x":"https://x.com/sebastienlorber","linkedin":"https://www.linkedin.com/in/sebastienlorber/","github":"https://github.com/slorber","newsletter":"https://thisweekinreact.com"},"imageURL":"https://github.com/slorber.png","key":"slorber"}],"frontMatter":{"slug":"mdx-blog-post","title":"MDX Blog Post","authors":["slorber"],"tags":["docusaurus"]},"unlisted":false,"prevItem":{"title":"Welcome","permalink":"/central-station/blog/welcome"},"nextItem":{"title":"Long Blog Post","permalink":"/central-station/blog/long-blog-post"}},"content":"Blog posts support [Docusaurus Markdown features](https://docusaurus.io/docs/markdown-features), such as [MDX](https://mdxjs.com/).\n\n:::tip\n\nUse the power of React to create interactive blog posts.\n\n:::\n\n{/* truncate */}\n\nFor example, use JSX to create an interactive button:\n\n```js\n<button onClick={() => alert('button clicked!')}>Click me!</button>\n```\n\n<button onClick={() => alert('button clicked!')}>Click me!</button>"},{"id":"long-blog-post","metadata":{"permalink":"/central-station/blog/long-blog-post","editUrl":"https://github.com/playrunner/central-station/tree/main/docs/blog/2019-05-29-long-blog-post.mdx","source":"@site/blog/2019-05-29-long-blog-post.mdx","title":"Long Blog Post","description":"This is the summary of a very long blog post,","date":"2019-05-29T00:00:00.000Z","tags":[{"inline":false,"label":"Hello","permalink":"/central-station/blog/tags/hello","description":"Hello tag description"},{"inline":false,"label":"Docusaurus","permalink":"/central-station/blog/tags/docusaurus","description":"Docusaurus tag description"}],"readingTime":2.04,"hasTruncateMarker":true,"authors":[{"name":"Yangshun Tay","title":"Ex-Meta Staff Engineer, Co-founder GreatFrontEnd","url":"https://linkedin.com/in/yangshun","page":{"permalink":"/central-station/blog/authors/yangshun"},"socials":{"x":"https://x.com/yangshunz","linkedin":"https://www.linkedin.com/in/yangshun/","github":"https://github.com/yangshun","newsletter":"https://www.greatfrontend.com"},"imageURL":"https://github.com/yangshun.png","key":"yangshun"}],"frontMatter":{"slug":"long-blog-post","title":"Long Blog Post","authors":"yangshun","tags":["hello","docusa