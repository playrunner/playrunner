  "scripts": {
    "dev": "./start-local.sh",
    "dev:setup": "./start-local.sh --setup",
    "build": "npm run build --prefix apps/frontend && npm run build --prefix apps/runners/orchestrator",
    "test:e2e": "npm run e2e --prefix apps/frontend --",
    "test:e2e:mock": "PLAYRUNNER_E2E_MODE=mock npm run e2e --prefix apps/frontend --",
    "test:e2e:live": "PLAYRUNNER_E2E_MODE=live npm run e2e --prefix apps/frontend --",
    "test:integration-composition": "node --test infra/scripts/generate-integration-composition.test.mjs"
  }
}
