{
  "name": "@playrunner/gcp",
  "version": "0.1.1",
  "description": "Google Cloud runner integration package for Playrunner.",
  "keywords": [
    "playrunner",
    "gcp",
    "integration"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "author": "Concept AI PTY LTD",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/playrunner/playrunner.git",
    "directory": "packages/gcp"
  },
  "homepage": "https://playrunner.dev/docs/integration-packages/gcp/",
  "bugs": {
    "url": "https://github.com/playrunner/playrunner/issues"
  },
  "type": "module",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "playrunner": {
    "integration": {
      "id": "gcp",
      "frontend": ".",
      "api": "./api",
      "e2e": "./e2e"
    }
  },
  "exports": {
    ".": {
      "types": "./src/frontend/index.tsx",
      "import": "./src/frontend/index.tsx",
      "require": "./src/frontend/index.tsx",
      "default": "./src/frontend/index.tsx"
    },
    "./frontend": {
      "types": "./src/frontend/index.tsx",
      "import": "./src/frontend/index.tsx",
      "require": "./src/frontend/index.tsx",
      "default": "./src/frontend/index.tsx"
    },
    "./api": {
      "types": "./src/api/index.ts",
      "import": "./src/api/index.ts",
      "require": "./src/api/index.ts",
      "default": "./src/api/index.ts"
    },
    "./api-runtime": {
      "types": "./src/api-runtime/index.ts",
      "import": "./src/api-runtime/index.ts",
      "require": "./src/api-runtime/index.ts",
      "default": "./src/api-runtime/index.ts"
    },
    "./e2e": {
      "types": "./src/e2e/index.ts",
      "import": "./src/e2e/index.ts",
      "require": "./src/e2e/index.ts",
      "default": "./src/e2e/index.ts"
    },
    "./assets/gcp.svg": "./assets/gcp.svg"
  },
  "files": [
    "LICENSE",
    "README.md",
    "assets",
    "src"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/run": "^3.2.1",
    "@google-cloud/storage": "^7.19.0",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2"
  },
  "peerDependencies": {
    "@playwright/test": "^1.61.0",
    "@playrunner/integration-sdk": "^0.1.0",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    },
    "@playrunner/integration-sdk": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.61.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "lucide-react": "^0.546.0",
    "prettier": "3.8.4",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.61.1"
  }
}
