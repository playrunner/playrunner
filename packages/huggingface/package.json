{
  "name": "@playrunner/huggingface",
  "version": "0.1.0",
  "description": "Hugging Face inference integration package for Playrunner.",
  "keywords": [
    "playrunner",
    "huggingface",
    "inference",
    "integration"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "author": "Concept AI PTY LTD",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/playrunner/playrunner.git",
    "directory": "packages/huggingface"
  },
  "bugs": {
    "url": "https://github.com/playrunner/playrunner/issues"
  },
  "homepage": "https://playrunner.dev/docs/integration-packages/huggingface/",
  "type": "module",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "playrunner": {
    "integration": {
      "id": "huggingface",
      "frontend": ".",
      "orchestrator": "./orchestrator"
    }
  },
  "exports": {
    ".": {
      "types": "./src/frontend/index.tsx",
      "import": "./src/frontend/index.tsx",
      "require": "./src/frontend/index.tsx",
      "default": "./src/frontend/index.tsx"
    },
    "./frontend": {
      "types": "./src/frontend/index.tsx",
      "import": "./src/frontend/index.tsx",
      "require": "./src/frontend/index.tsx",
      "default": "./src/frontend/index.tsx"
    },
    "./orchestrator": {
      "types": "./src/orchestrator/index.ts",
      "import": "./src/orchestrator/index.ts",
      "require": "./src/orchestrator/index.ts",
      "default": "./src/orchestrator/index.ts"
    },
    "./assets/huggingface.svg": "./assets/huggingface.svg"
  },
  "files": [
    "LICENSE",
    "README.md",
    "assets",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "NODE_OPTIONS=--preserve-symlinks tsx --test src/*.test.ts src/orchestrator/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.23"
  },
  "peerDependencies": {
    "@playrunner/integration-sdk": "^0.1.0",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@playrunner/integration-sdk": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "prettier": "3.8.4",
    "tsx": "^4.23.1",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.61.1"
  }
}
