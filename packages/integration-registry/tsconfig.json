{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "declaration": false,
    "noEmit": true,
    "paths": {
      "@playrunner/github": ["../github/src/frontend/index.tsx"],
      "@playrunner/integration-sdk": [
        "../integration-sdk/src/frontend/index.tsx"
      ]
    }
  },
  "include": ["src"]
}
